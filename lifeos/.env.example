# LifeOS Docker environment template
# Copy this file before first run:
#   cp .env.example .env
#
# Required secrets before a real deployment:
#   - POSTGRES_PASSWORD
#   - JWT_SECRET
# Optional but recommended for unattended first boot:
#   - ADMIN_EMAIL
#   - ADMIN_PASSWORD
# Optional for licensed installs:
#   - APP_LICENSE_KEY

# ----------------------------------------------------------------------------
# Compose profile selection
# ----------------------------------------------------------------------------
# Default profile used when you run `docker compose up -d` without flags.
# Set to `dev` for local testing or `prod` for a long-running deployment.
COMPOSE_PROFILES=prod

# ----------------------------------------------------------------------------
# Public app access
# ----------------------------------------------------------------------------
# HTTP port exposed by the LifeOS frontend container.
APP_PORT=3377
# HTTPS port exposed if you mount certificates into ./ssl.
HTTPS_PORT=3378
# Public URL users will open in the browser.
LIFEOS_URL=http://localhost:3377

# ----------------------------------------------------------------------------
# PostgreSQL settings
# ----------------------------------------------------------------------------
# These defaults match docker-compose.yml. Change the password immediately.
POSTGRES_DB=lifeos
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=change-me-strong-db-password

# ----------------------------------------------------------------------------
# Backend security and licensing
# ----------------------------------------------------------------------------
# Use a long random value (for example 32+ characters from a password manager).
JWT_SECRET=change-me-long-random-jwt-secret
# Keep the default unless you run your own license validation endpoint.
LICENSE_API_URL=https://abcytwvuntyicdknpzju.supabase.co/functions/v1/verify-license
# Leave blank if you do not have a license key yet.
APP_LICENSE_KEY=
# Optional: custom URL used by Admin Panel "Download lifeos.exe" button.
VITE_WINDOWS_EXE_URL=

# ----------------------------------------------------------------------------
# Optional bootstrap values
# ----------------------------------------------------------------------------
# Leave blank to create the first admin in the UI bootstrap flow.
ADMIN_EMAIL=
ADMIN_PASSWORD=
